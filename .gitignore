# ============================================
# Python 缓存和临时文件
# ============================================
# ╔══════════════════════════════════════════════════╗
# ║  Learned Workspace Facts                        ║
# ║  .gitignore 完善: 按功能分组（Python 缓存、     ║
# ║  运行时数据、AI 中间产物、环境变量、构建产物、   ║
# ║  安装程序、OS 文件），每项带中文注释。           ║
# ╚══════════════════════════════════════════════════╝
__pycache__/
*.pyc
*.pyo
*.pyd
*.log
*.tmp
*.swp
*.bak

# ============================================
# 运行时数据 / 会话记录（含用户敏感信息）
# ============================================
sessions/


# ============================================
# AI 智能体工作流中间产物（不对外公开）
# ============================================
.claude/
.hybrid/
.trae/

# ============================================
# 环境变量与私密配置
# ============================================
.env

# ============================================
# 构建产物（PyInstaller + Inno Setup）
# ============================================
build/
dist/
*.spec
becode_venv/

# ============================================
# 安装程序依赖及输出
# ============================================
inno_setup.exe
installer/inno_setup.exe
installer/BeCode_Setup*.exe


# ============================================
# 打包产物内部残留（被 PyInstaller 打包进去的敏感文件）
# ============================================
dist/becode/_internal/.env

# ============================================
# 操作系统特定文件
# ============================================
.DS_Store
Thumbs.db
